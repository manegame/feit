---
import { getAllPagesAndLayout, pagesSlugToModelApiKeyMap } from "../cms/dato";

import Layout from "../layouts/Layout.astro";
import Page from "../components/global/Page.astro";

const data = await getAllPagesAndLayout();
const slugToModelApiKeyMap = pagesSlugToModelApiKeyMap(data.pages);

// The directorsPageFeit singleton has no slug, so it's stored with key "undefined"
const page = data.pages["undefined"];
---

<Layout
    layout={data.layout}
    slugToModelApiKeyMap={slugToModelApiKeyMap}
    template={page._modelApiKey}
    seoMetaTags={page._seoMetaTags}
>
    <Page data={page} />
</Layout>
